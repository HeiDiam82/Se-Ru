{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "variables": {
        "NIXPACKS_NPM_INSTALL_CMD": "npm install --no-package-lock",
        "NIXPACKS_NODE_VERSION": "20"
      }
    }
  },
  "deploy": {
    "releaseCommand": "php artisan migrate --force"
  }
}
